"""
Question 12:
Write a function factorial() that takes in an integer n as a parameter and 
returns its factorial. The factorial of a number is the product of all positive 
integers less than or equal to that number. For example, the factorial of 5 
(denoted as 5!) is 5! = 5 * 4 * 3 * 2 * 1 which equals 120.
"""

def factorial(n):
    product = 1
    for x in range(n):
        product *= x+1
    return product    

print(factorial(7))

"""
Question 13:
Write a function squares() that takes a list of integers nums as a parameter and 
returns a new list containing the square of each number in the original list.
"""

def squares(nums): # method modifying in place
    for number in range(len(nums)): # interate through the list
        nums[number] = nums[number] * nums[number]
    return nums

def squares(nums): # method creating new list
    new_list = []
    for number in nums:
        new_list.append(number*number)
    return new_list 

nums = [1, 2, 3, 4, 17]
print(squares(nums))

