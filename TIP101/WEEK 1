"""
Question 5:
Write a function find_missing() that takes in a list nums containing n unique numbers in 
the range [0,n]. The function returns the only number in the range that is missing from the list.
"""

def find_missing(nums):
    nums.sort() # sort the number
    for index in range(len(nums)):
        if index != nums[index]: # compare the index value, to the value that is currently there
            return index
    return None

nums = [2,4,1,0,5]
missing_num = find_missing(nums)
print(missing_num)

